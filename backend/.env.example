# Copy to `.env` in this same directory (`backend/`) — the API loads that file by absolute path.
#
# Application
ENVIRONMENT=local

# CORS: comma-separated origins (no spaces), e.g. http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database — async SQLAlchemy + asyncpg (use Supabase "URI" or local pgvector compose)
# Local Docker compose maps Postgres to host port 5433 by default (see repo docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://support:support@127.0.0.1:5433/support_intelligence
# Supabase transaction pooler (port 6543 / Supavisor): asyncpg must use statement_cache_size=0.
# The API sets this automatically when DATABASE_URL contains pooler.supabase.com or :6543 on *.supabase.co.
# ASYNCPG_STATEMENT_CACHE_SIZE=0

# Supabase JWT — required for authenticated routes
# - Legacy HS256: set SUPABASE_JWT_SECRET (Dashboard → JWT Keys → Legacy JWT Secret).
# - New signing keys (ECC ES256 / RSA): leave SUPABASE_JWT_SECRET empty; API verifies via
#   JWKS at https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json (from token `iss`).
SUPABASE_JWT_SECRET=

# OpenAI — embeddings (Phase 2 RAG)
OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200

# Copilot (Phase 3) — Responses API + pgvector retrieval
# COPILOT_MODEL=gpt-4o-mini
# COPILOT_RETRIEVAL_TOP_K=8
# COPILOT_MIN_EVIDENCE_SCORE=0.22
# COPILOT_MAX_HISTORY_MESSAGES=12
