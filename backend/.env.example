# Application
ENVIRONMENT=local

# CORS: comma-separated origins (no spaces), e.g. http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database — async SQLAlchemy + asyncpg (use Supabase "URI" or local pgvector compose)
DATABASE_URL=postgresql+asyncpg://support:support@localhost:5432/support_intelligence

# Supabase JWT (Settings → API → JWT Secret) — required for /documents and /retrieve
SUPABASE_JWT_SECRET=

# OpenAI — embeddings (Phase 2 RAG)
OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
