# ---------------------------------------------------------------------------
# FastAPI（浏览器可访问）
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Supabase — 前端只用「公开」密钥，不要用 Secret / service_role
# ---------------------------------------------------------------------------
# Project URL：Integrations → Data API → API URL
#   形如 https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# 浏览器端密钥（二选一，填同一个即可）：
#   新版控制台：Settings → API Keys →「Publishable key」里 default 那一串（sb_publishable_...）
#   旧版标签：同一页切到「Legacy anon, service_role」→ 复制 anon public（eyJ...）
# 切勿把「Secret keys / sb_secret_」写进前端，也不要提交到 Git。
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_OR_legacy_anon_paste_here

# 可选：若你想语义更清晰，也可以用下面这个名字代替上一行（代码里二选一即可）
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
